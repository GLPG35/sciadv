---
import type { GetStaticPaths } from "astro";
import Layout from "../../../../layouts/Layout.astro"
import sideContent from '../../../../utils/sidecontent_es.json'
import './styles.scss'
import EntryPercent from "../../../../components/EntryPercent"
import SideContentList from "../../../../components/SideContentList/es"
import type { Title } from "../../../../store/entryStore"
import { LuChevronLeft, LuChevronRight } from "react-icons/lu"

export const getStaticPaths = (() => {
	return sideContent.map(({ name }) => ({
		params: { entry: name }
	}))
}) satisfies GetStaticPaths

const entry = sideContent.find(x => x.name == Astro.params.entry)

if (!entry) return Astro.redirect('/404')

const prevEntry = sideContent.findIndex(x => x.name === Astro.params.entry) === 0 ? null : sideContent.findIndex(x => x.name === Astro.params.entry) - 1
const nextEntry = sideContent.findIndex(x => x.name === Astro.params.entry) === sideContent.length - 1 ? null : sideContent.findIndex(x => x.name === Astro.params.entry) + 1

const anim = {
	old: {
		name: "bezier",
		duration: "0.4s",
		easing: "cubic-bezier(0.65,0.05,0.36,1)",
		direction: "reverse"
	},
	new: {
		name: "bezier",
		duration: "0.4s",
		easing: "cubic-bezier(0.65,0.05,0.36,1)"
	}
}

const customTransition = {
	forwards: anim,
	backwards: anim
}
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
		<link rel="shortcut icon" href="/favicon/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="SciADV Series" />
		<link rel="manifest" href="/favicon/site.webmanifest" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>SciADV Series - {entry.title} Contenido Extra</title>
		<meta name="description" content={entry.epigraph} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={`SciADV Series - ${entry.title}`} />
		<meta property="og:description" content={entry.epigraph} />
		<meta property="og:url" content="https://sciadvseri.es/" />
		<meta property="og:image" content={`https://sciadvseri.es${entry.cardOg}`} />
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://sciadvseri.es/" />
		<meta property="twitter:title" content={`SciADV Series - ${entry.title}`} />
		<meta property="twitter:description" content={entry.epigraph} />
		<meta property="twitter:image" content={`https://sciadvseri.es${entry.card}`} />
	</head>
	<body>
		<Layout>
			<div class="entry">
				<div class="summary">
					<div class="coverWrapper">
						<div class="cover" transition:name={`side-cover-${entry.name}`} transition:animate={customTransition}>
							<picture>
								{entry.logo.map((src, i) => {
									if (entry.logo.length === i + 1) return <img src={src} alt='' />

									const type = src.split('.').pop()
									return <source srcset={src} type={`image/${type}`} />
								})}
							</picture>
						</div>
						<EntryPercent title={entry.name as Title} list={entry.list} client:load />
					</div>
					<div class="text">
						<div class="title">
							<h2>{entry.title}</h2>
							<span>Contenido Extra</span>
							<div class="prevNext">
								{prevEntry !== null && <a href={`/es/sidecontent/${sideContent[prevEntry].name}`}><LuChevronLeft /> Anterior</a>}
								{nextEntry !== null && <a href={`/es/sidecontent/${sideContent[nextEntry].name}`}>Siguiente <LuChevronRight /></a>}
							</div>
						</div>
						<div class="list">
							<SideContentList title={entry.name as Title} list={entry.list} url={Astro.url} client:idle />
						</div>
					</div>
				</div>
				{entry.faq &&
					<div class="section">
						<h3>Preguntas y respuestas</h3>
						<div class="questions">
							{entry.faq.map(({ question, answer }) => (
								<div class="question">
									<h4>{question}</h4>
									{answer.map(paragraph => {
										if (typeof paragraph === 'object') {
											return <ul>
												{paragraph.map(li => <li>{li}</li>)}
											</ul>
										}
									
										return <p set:html={paragraph}></p>
									})}
								</div>
							))}
						</div>
					</div>
				}
			</div>
		</Layout>
	</body>
</html>
